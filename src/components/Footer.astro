---
// Footer navigation component
import instagramSvg from '../assets/instagram.svg?raw';
---
<footer>
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <h3>La Juste Nuance</h3>
        <p>Accompagnement en image de soi aux Clayes-sous-Bois (Yvelines). Conçu pour révéler ton essence et ton rayonnement.</p>
      </div>
      
      <div class="footer-links">
        <h4>Navigation</h4>
        <nav aria-label="Navigation secondaire">
          <ul>
            <li><a href="/la-juste-nuance-site/">Accueil</a></li>
            <li><a href="/la-juste-nuance-site/#services">Accompagnements</a></li>
            <li><a href="/la-juste-nuance-site/about">A propos</a></li>
            <li><a href="/la-juste-nuance-site/#faq">FAQ</a></li>
          </ul>
        </nav>
      </div>
      
      <div class="footer-contact">
        <h4>Contact & Accès</h4>
        <p style="margin-bottom: 0.8rem;">
          <strong>E-mail :</strong> <br>
          <a href="mailto:florence.corolleur@gmail.com">florence.corolleur@gmail.com</a>
        </p>
        <p>
          <strong>Lieu :</strong> <br>
          Les Clayes-sous-Bois (78340) & Yvelines limitrophes
        </p>
      </div>
      
      <div class="footer-social-legal">
        <h4>Légal & Réseaux</h4>
        <nav aria-label="Liens légaux">
          <ul style="margin-bottom: 1.2rem;">
            <li><a href="/la-juste-nuance-site/mentions-legales">Mentions Légales</a></li>
            <li><a href="/la-juste-nuance-site/politique-confidentialite">Politique de Confidentialité</a></li>
          </ul>
        </nav>
        <div class="social-icons">
          <a href="https://www.instagram.com/la_juste_nuance" target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="Instagram">
            <Fragment set:html={instagramSvg} />
          </a>
          <a href="https://www.facebook.com/profile.php?id=61590238631048" target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="Facebook">
            <svg viewBox="0 0 24 24"><path d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z"/></svg>
          </a>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; 2026 La Juste Nuance. Tous droits réservés.</p>
      <p>Photos par <a href="https://annebiedphotographe.com" class="credit-link" target="_blank" rel="noopener noreferrer">Anne Bied</a></p>
    </div>
  </div>
</footer>
