---
// Header navigation component
import instagramSvg from '../assets/instagram.svg?raw';
---
<header>
  <div class="header-container">
    <div class="header-left">
      <a href="/la-juste-nuance-site/" class="logo">
        <img src="images/Conseil_en_image_les_Clayes_sous_Bois_logo.png" alt="La Juste Nuance logo">
      </a>
      <nav class="desktop-nav">
        <ul class="nav-links">
          <li><a href="/la-juste-nuance-site/">Accueil</a></li>
          <li><a href="/la-juste-nuance-site/#services">Accompagnements</a></li>
          <li><a href="/la-juste-nuance-site/about">A propos</a></li>
          <li><a href="/la-juste-nuance-site/#faq">FAQ</a></li>
          <!-- Social links (visible only inside the mobile menu drawer) -->
          <li class="mobile-only-socials">
            <div class="mobile-socials-wrapper">
              <a href="https://www.instagram.com/la_juste_nuance" target="_blank" rel="noopener noreferrer" class="header-social-link" aria-label="Instagram">
                <Fragment set:html={instagramSvg} />
              </a>
              <a href="https://www.facebook.com/profile.php?id=61590238631048" target="_blank" rel="noopener noreferrer" class="header-social-link" aria-label="Facebook">
                <svg viewBox="0 0 24 24"><path d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z"/></svg>
              </a>
            </div>
          </li>
          <li class="mobile-only"><a href="#" class="btn btn-primary btn-book" style="padding: 0.6rem 1.4rem; font-size: 0.85rem;">Réserver</a></li>
        </ul>
      </nav>
    </div>
    
    <div class="header-right">
      <div class="header-socials">
        <a href="https://www.instagram.com/la_juste_nuance" target="_blank" rel="noopener noreferrer" class="header-social-link" aria-label="Instagram">
          <Fragment set:html={instagramSvg} />
        </a>
        <a href="https://www.facebook.com/profile.php?id=61590238631048" target="_blank" rel="noopener noreferrer" class="header-social-link" aria-label="Facebook">
          <svg viewBox="0 0 24 24"><path d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z"/></svg>
        </a>
      </div>
      <a href="#" class="btn btn-primary btn-book header-btn">Réserver</a>
      
      <div class="burger">
        <div class="line1"></div>
        <div class="line2"></div>
        <div class="line3"></div>
      </div>
    </div>
  </div>
</header>
